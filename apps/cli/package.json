{
  "name": "ai-pkgs",
  "version": "0.0.6",
  "description": "A package manager for installing and managing AI agent skills.",
  "module": "dist/cli.js",
  "type": "module",
  "bin": {
    "ai-pkgs": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "ai-pkgs",
    "ai-skills",
    "agent-skills",
    "ai-agents",
    "cursor",
    "claude",
    "codex",
    "cli",
    "skills"
  ],
  "scripts": {
    "bump": "bumpp --commit \"chore: release ai-pkgs v%s\" --tag \"ai-pkgs-v%s\" --no-push",
    "build": "tsup",
    "check": "bun run type-check && bun run test:unit && bun run test:e2e && bun run lint",
    "dev": "bun --watch ./src/cli.ts",
    "index.ts": "bun ./src/cli.ts",
    "lint": "bunx biome check src tests tsup.config.ts package.json",
    "publish:dry": "bun run release && npm publish --dry-run",
    "release": "bun run check && bun run build",
    "release:publish": "bun run release && npm publish --access public",
    "start": "bun ./src/cli.ts",
    "test": "vitest run --coverage",
    "test:e2e": "vitest run --project e2e",
    "test:unit": "vitest run --project unit",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^4.1.5",
    "bumpp": "^11.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@clack/core": "^1.3.0",
    "@clack/prompts": "^1.3.0",
    "cac": "^7.0.0",
    "picocolors": "^1.1.1",
    "ts-pattern": "^5.9.0"
  }
}
