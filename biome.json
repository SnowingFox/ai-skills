{
  "$schema": "https://biomejs.dev/schemas/2.3.12/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "apps/cli/**",
      "apps/web/**",
      "package.json",
      "apps/cli/package.json",
      "apps/web/package.json",
      "biome.json",
      "!node_modules",
      "!apps/*/node_modules",
      "!apps/*/dist",
      "!apps/*/build",
      "!apps/web/.next",
      "!apps/web/.open-next",
      "!apps/web/.wrangler",
      "!apps/web/.source",
      "!apps/web/.cursor",
      "!apps/web/.claude",
      "!apps/web/.auto-claude",
      "!apps/web/.kiro",
      "!apps/web/.conductor",
      "!apps/web/.vscode",
      "!apps/web/next-env.d.ts",
      "!apps/web/src/db",
      "!apps/web/tailwind.config.ts",
      "!apps/web/src/lib/utils.ts",
      "!apps/web/src/hooks/use-mobile.ts",
      "!apps/web/cloudflare-env.d.ts",
      "!apps/web/open-next.config.ts",
      "!apps/web/src/components/ui",
      "!apps/web/src/components/ai-elements",
      "!apps/web/src/components/data-table",
      "!apps/web/src/app/\\[locale\\]/preview",
      "!apps/web/src/payment/types.ts",
      "!apps/web/src/credits/types.ts",
      "!apps/web/src/types/index.d.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "formatWithErrors": true
  },
  "assist": { "actions": { "source": { "organizeImports": "off" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useNodejsImportProtocol": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5",
      "semicolons": "always"
    }
  },
  "overrides": [
    {
      "includes": ["apps/web/**"],
      "assist": { "actions": { "source": { "organizeImports": "off" } } },
      "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 2,
        "lineWidth": 80,
        "formatWithErrors": true
      },
      "linter": {
        "enabled": true,
        "rules": {
          "recommended": true,
          "suspicious": {
            "noSparseArray": "off",
            "noArrayIndexKey": "off",
            "noExplicitAny": "off",
            "noShadowRestrictedNames": "off",
            "noNonNullAssertedOptionalChain": "off"
          },
          "complexity": {
            "noForEach": "off",
            "noUselessFragments": "off",
            "noImportantStyles": "off"
          },
          "correctness": {
            "useExhaustiveDependencies": "off",
            "noUnusedVariables": "off",
            "noUnusedFunctionParameters": "off",
            "noUnusedImports": "off",
            "useHookAtTopLevel": "off",
            "useParseIntRadix": "off"
          },
          "performance": {
            "noDynamicNamespaceImportAccess": "off",
            "noImgElement": "off"
          },
          "style": {
            "useTemplate": "off",
            "noNonNullAssertion": "off",
            "useNodejsImportProtocol": "off",
            "useConsistentArrayType": {
              "level": "off",
              "options": { "syntax": "shorthand" }
            }
          },
          "a11y": {
            "useValidAnchor": "off",
            "noSvgWithoutTitle": "off",
            "useKeyWithClickEvents": "off",
            "noStaticElementInteractions": "off"
          }
        }
      },
      "javascript": {
        "formatter": {
          "quoteStyle": "single",
          "trailingCommas": "es5",
          "semicolons": "always"
        }
      },
      "css": {
        "parser": {
          "cssModules": true,
          "tailwindDirectives": true
        }
      }
    }
  ]
}
