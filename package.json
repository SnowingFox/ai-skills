{
  "name": "ai-skills",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --filter ai-skills-web dev",
    "build": "bun run --filter ai-skills-web build",
    "build:analyze": "bun run --filter ai-skills-web build:analyze",
    "start": "bun run --filter ai-skills-web start",
    "preview": "bun run --filter ai-skills-web preview",
    "deploy": "bun run --filter ai-skills-web deploy",
    "upload": "bun run --filter ai-skills-web upload",
    "email": "bun run --filter ai-skills-web email",
    "auth:schema:generate": "bun run --filter ai-skills-web auth:schema:generate",
    "db:generate": "bun run --filter ai-skills-web db:generate",
    "db:migrate": "bun run --filter ai-skills-web db:migrate",
    "db:push": "bun run --filter ai-skills-web db:push",
    "db:studio": "bun run --filter ai-skills-web db:studio",
    "list-contacts": "bun run --filter ai-skills-web list-contacts",
    "list-users": "bun run --filter ai-skills-web list-users",
    "fix-payments": "bun run --filter ai-skills-web fix-payments",
    "fix-payments-scene": "bun run --filter ai-skills-web fix-payments-scene",
    "distribute-credits": "bun run --filter ai-skills-web distribute-credits",
    "cf-typegen": "bun run --filter ai-skills-web cf-typegen",
    "knip": "bun run --filter ai-skills-web knip",
    "dev:cli": "bun run --filter ai-pkgs dev",
    "start:cli": "bun run --filter ai-pkgs start",
    "type-check:cli": "bun run --filter ai-pkgs type-check",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.12"
  }
}
